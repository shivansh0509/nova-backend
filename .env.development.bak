# ─── NOVA Backend — Development Environment ──────────────────────────────────
NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nova?schema=public"
REDIS_HOST="localhost"
REDIS_PORT=6379
JWT_SECRET="dev-jwt-secret-not-for-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="dev-refresh-secret-not-for-production"
REFRESH_TOKEN_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"
COOKIE_SECRET="dev-cookie-secret-not-for-production"
SWAGGER_ENABLED=true
LOG_LEVEL="debug"
PRISMA_CLIENT_ENGINE_TYPE="library"
